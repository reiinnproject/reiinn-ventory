# MongoDB connection string (from MongoDB Atlas)
# Format: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/reiinn_ventory?retryWrites=true&w=majority
# See docs/MONGODB_SETUP.md for setup instructions
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/reiinn_ventory?retryWrites=true&w=majority

# JWT secret for auth tokens (generate a random string)
JWT_SECRET=your-secret-key-here
